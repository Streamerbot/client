{
  "name": "@streamerbot/client",
  "version": "1.12.2",
  "description": "Streamer.bot WebSocket client library",
  "author": "Whipstickgostop <https://github.com/whiptsickgostop>",
  "license": "MIT",
  "homepage": "https://streamerbot.github.io/client",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/streamerbot/client.git",
    "directory": "packages/client"
  },
  "keywords": [
    "streamerbot",
    "websocket",
    "client"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "browser": "dist/streamerbot-client.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "browser": "./dist/streamerbot-client.js"
    }
  },
  "files": [
    "dist/*"
  ],
  "scripts": {
    "dev": "pnpm build --watch",
    "build": "tsdown",
    "test": "vitest run",
    "lint": "tsc",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "tsdown": "^0.22.12",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "uncrypto": "^0.1.3"
  }
}